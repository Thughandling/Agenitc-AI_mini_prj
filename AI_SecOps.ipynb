      "source": [
        "## State 정의\n",
        "\n",
        "그래프 전체에서 공유하는 **공책**. 각 Node는 필요한 필드를 읽고, 결과 dict를 반환해 State에 **병합**.\n"
      ],
      "id": "k2kvx8919oJa"
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "yF45KraL9oJa"
      },
      "source": [
        "from typing import TypedDict, Any\n",
        "\n",
        "\n",
        "class SOCState(TypedDict, total=False):\n",
        "    # ── 입력 ──\n",
        "    raw_log: str | dict\n",
        "    log_type: str\n",
        "\n",
        "    # ── Node 결과 (순서대로 채워짐) ──\n",
        "    parsed_log: ParsedLog\n",
        "    classification: ClassificationResult\n",
        "    red_team: RedTeamAnalysis\n",
        "    blue_team: BlueTeamAnalysis\n",
        "    verdict: JudgeVerdict\n",
        "    mitre: MitreMapping\n",
        "    incident_report: IncidentReport\n"
      ],
      "outputs": [],
      "execution_count": 23,
      "id": "yF45KraL9oJa"
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "M7AL05AX9oJa"
      },
      "source": [
        "## Node 정의\n",
        "\n",
        "각 함수: `state` 읽기 → 작업 → `{필드: 값}` 반환 (강의와 동일 패턴)\n"
      ],
      "id": "M7AL05AX9oJa"
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "PeFQFB6i9oJa"
      },
      "source": [
        "# [Node 1] Parser — LLM 없음\n",
        "def parse_node(state: SOCState):\n",
        "    print(\"\\n--- [1] Parser: 로그 파싱 + IOC 추출 ---\")\n",
        "    parsed = parse_log(state[\"raw_log\"], state.get(\"log_type\", \"auto\"))\n",
        "    print(f\"  log_type={parsed.log_type}, IOC {len(parsed.iocs)}개\")\n",
        "    return {\"parsed_log\": parsed}\n"
      ],
      "outputs": [],
      "execution_count": 24,
      "id": "PeFQFB6i9oJa"
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "rYGMvcXj9oJa"
      },
      "source": [
        "# [Node 2] Classifier\n",
        "def classify_node(state: SOCState):\n",
        "    print(\"\\n--- [2] Classifier ---\")\n",
        "    p = state[\"parsed_log\"]\n",
        "    result = ask_json(model,\n",
        "        \"Attack Classification Agent. JSON: is_attack, confidence, attack_type, summary\",\n",
        "        f\"로그:\\n{p.raw[:2500]}\", log_raw=p.raw, schema=ClassificationResult)\n",
        "    return {\"classification\": ClassificationResult.model_validate(result)}\n"
      ],
      "outputs": [],
      "execution_count": 25,
      "id": "rYGMvcXj9oJa"
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "SPnhHN6r9oJb"
      },
      "source": [
        "# [Node 3a] Red Team\n",
        "def red_team_node(state: SOCState):\n",
        "    print(\"\\n--- [3a] Red Team ---\")\n",
        "    p, c = state[\"parsed_log\"], state[\"classification\"]\n",
        "    result = ask_json(model,\n",
        "        \"Red Team Agent. JSON: attack_hypothesis, evidence, confidence\",\n",
        "        f\"classify={c.model_dump_json()}\\n로그:\\n{p.raw[:2500]}\", log_raw=p.raw, schema=RedTeamAnalysis)\n",
        "    return {\"red_team\": RedTeamAnalysis.model_validate(result)}\n"
      ],
      "outputs": [],
      "execution_count": 26,
      "id": "SPnhHN6r9oJb"
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "XC2tFhO09oJb"
      },
      "source": [
        "# [Node 3b] Blue Team\n",
        "def blue_team_node(state: SOCState):\n",
        "    print(\"\\n--- [3b] Blue Team ---\")\n",
        "    p, c = state[\"parsed_log\"], state[\"classification\"]\n",
        "    result = ask_json(model,\n",
        "        \"Blue Team Agent. JSON: benign_hypothesis, evidence, confidence\",\n",
        "        f\"classify={c.model_dump_json()}\\n로그:\\n{p.raw[:2500]}\", log_raw=p.raw, schema=BlueTeamAnalysis)\n",
        "    return {\"blue_team\": BlueTeamAnalysis.model_validate(result)}\n"
      ],
      "outputs": [],
      "execution_count": 27,
      "id": "XC2tFhO09oJb"
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "6_zNukFN9oJb"
      },
      "source": [
        "# [Node 4] Judge — Red/Blue 종합 + 최종 판단 근거\n",
        "def judge_node(state: SOCState):\n",
        "    print(\"\\n--- [4] Judge: 최종 판정 + 판단 근거 ---\")\n",
        "    p = state[\"parsed_log\"]\n",
        "    c, r, b = state[\"classification\"], state[\"red_team\"], state[\"blue_team\"]\n",
        "    result = ask_json(model,\n",
        "        \"\"\"Judge Agent (SOC Lead). Red vs Blue 종합 판정.\n",
        "JSON: verdict, tp_fp, confidence, rationale(한줄), final_rationale(4~6문장 한국어, Red/Blue 비교·IOC 연결)\"\"\",\n",
        "        f\"classify={c.model_dump_json()}\\nred={r.model_dump_json()}\\nblue={b.model_dump_json()}\\niocs={[i.model_dump() for i in p.iocs]}\\nlog={p.raw[:2000]}\",\n",
        "        log_raw=p.raw, schema=JudgeVerdict)\n",
        "    if not result.get(\"final_rationale\"):\n",
        "        result[\"final_rationale\"] = result.get(\"rationale\", \"\")\n",
        "    return {\"verdict\": JudgeVerdict.model_validate(result)}\n"
      ],
      "outputs": [],
      "execution_count": 28,
      "id": "6_zNukFN9oJb"
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "EGRcSacz9oJb"
      },
      "source": [
        "# [Node 5] MITRE\n",
        "def mitre_node(state: SOCState):\n",
        "    print(\"\\n--- [5] MITRE ---\")\n",
        "    p = state[\"parsed_log\"]\n",
        "    result = ask_json(model,\n",
        "        \"MITRE Agent. JSON: technique_ids, recommendations, severity\",\n",
        "        f\"verdict={state['verdict'].model_dump_json()}\", log_raw=p.raw, schema=MitreMapping)\n",
        "    return {\"mitre\": MitreMapping.model_validate(result)}\n"
      ],
      "outputs": [],
      "execution_count": 29,
      "id": "EGRcSacz9oJb"
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "wQ15aF0X9oJb"
      },
      "source": [
        "# [Node 6] Report\n",
        "def report_node(state: SOCState):\n",
        "    print(\"\\n--- [6] Report ---\")\n",
        "    p = state[\"parsed_log\"]\n",
        "    result = ask_json(model,\n",
        "        \"Incident Report Agent. JSON: title, executive_summary, full_report_markdown\",\n",
        "        f\"verdict={state['verdict'].model_dump_json()}\\nmitre={state['mitre'].model_dump_json()}\",\n",
        "        log_raw=p.raw, schema=IncidentReport)\n",
        "    return {\"incident_report\": IncidentReport.model_validate(result)}\n"
      ],
      "outputs": [],
      "execution_count": 30,
      "id": "wQ15aF0X9oJb"
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "jLOIwzFQ9oJc"
      },
      "source": [
        "## 그래프 생성\n",
        "\n",
        "```\n",
        "START → parse → classify → [red_team ∥ blue_team] → judge → mitre → report → END\n",
        "```\n"
      ],
      "id": "jLOIwzFQ9oJc"
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "xbndVuGL9oJc",
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 747
        },
        "outputId": "eacf400a-ebc1-4bd4-e868-322bcb1db098"
      },
      "source": [
        "from langgraph.graph import StateGraph, START, END\n",
        "\n",
        "workflow = StateGraph(SOCState)\n",
        "\n",
        "# 노드 등록\n",
        "workflow.add_node(\"parse\", parse_node)\n",
        "workflow.add_node(\"classify\", classify_node)\n",
        "workflow.add_node(\"red_team\", red_team_node)\n",
        "workflow.add_node(\"blue_team\", blue_team_node)\n",
        "workflow.add_node(\"judge\", judge_node)\n",
        "workflow.add_node(\"mitre\", mitre_node)\n",
        "workflow.add_node(\"report\", report_node)\n",
        "\n",
        "# 엣지 연결\n",
        "workflow.add_edge(START, \"parse\")\n",
        "workflow.add_edge(\"parse\", \"classify\")\n",
        "workflow.add_edge(\"classify\", \"red_team\")   # 병렬 분기\n",
        "workflow.add_edge(\"classify\", \"blue_team\")   # 병렬 분기\n",
        "workflow.add_edge(\"red_team\", \"judge\")       # 합류\n",
        "workflow.add_edge(\"blue_team\", \"judge\")      # 합류\n",
        "workflow.add_edge(\"judge\", \"mitre\")\n",
        "workflow.add_edge(\"mitre\", \"report\")\n",
        "workflow.add_edge(\"report\", END)\n",
        "\n",
        "app = workflow.compile()\n",
        "app\n"
      ],
      "outputs": [
        {
          "output_type": "execute_result",
          "data": {
            "text/plain": [
              "<langgraph.graph.state.CompiledStateGraph object at 0x7f347ebff710>"
            ],
            "image/png": "\n"
          },
          "metadata": {},
          "execution_count": 31
        }
      ],
      "execution_count": 31,
      "id": "xbndVuGL9oJc"
    },
