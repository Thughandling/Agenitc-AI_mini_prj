            "\n",
            "--- [2] Classifier ---\n",
            "\n",
            "--- [3b] Blue Team ---\n",
            "\n",
            "--- [3a] Red Team ---\n",
            "\n",
            "--- [4] Judge: 최종 판정 + 판단 근거 ---\n",
            "\n",
            "--- [5] MITRE ---\n",
            "\n",
            "--- [6] Report ---\n"
          ]
        }
